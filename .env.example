# ============================================================
# Project Elixer — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# Gemini API (Google AI Studio → https://aistudio.google.com)
# ----------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ----------------------------------------------------------
# Local LLM — path to your .gguf model file
# Examples:
#   Linux/Mac : /home/yourname/models/Llama-3.1-8B-Instruct-Q4_K_M.gguf
#   Windows   : C:\Users\yourname\Downloads\Llama-3.1-8B-Instruct-Q4_K_M.gguf
# ----------------------------------------------------------
MODEL_PATH=/path/to/your/model.gguf

# ----------------------------------------------------------
# Piper TTS (optional — leave blank to disable voice output)
# ----------------------------------------------------------
PIPER_EXECUTABLE=/path/to/piper/piper
PIPER_VOICES_DIR=/path/to/voices

# ----------------------------------------------------------
# Flask server settings
# ----------------------------------------------------------
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# ----------------------------------------------------------
# Embedding model cache
# ----------------------------------------------------------
HF_HOME=./hf_cache
TRANSFORMERS_OFFLINE=1
HF_HUB_OFFLINE=1
